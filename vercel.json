{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "destination": "/avalon/zh-TW",
      "permanent": false
    },
    {
      "source": "/avalon",
      "destination": "/avalon/zh-TW",
      "permanent": false
    },
    {
      "source": "/:lang(zh-TW|en|de|fr|ja|ko|pl|ru|vi|pt|it|nl|cs|sv|th|id|es|zh-CN)/avalon",
      "destination": "/avalon/:lang",
      "permanent": true
    },
    {
      "source": "/:lang(zh-TW|en|de|fr|ja|ko|pl|ru|vi|pt|it|nl|cs|sv|th|id|es|zh-CN)/avalon/:path*",
      "destination": "/avalon/:lang/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/avalon/:lang(zh-TW|en|de|fr|ja|ko|pl|ru|vi|pt|it|nl|cs|sv|th|id|es|zh-CN)",
      "destination": "/avalon/index.html"
    },
    {
      "source": "/avalon/:lang(zh-TW|en|de|fr|ja|ko|pl|ru|vi|pt|it|nl|cs|sv|th|id|es|zh-CN)/",
      "destination": "/avalon/index.html"
    },
    {
      "source": "/avalon/:lang(zh-TW|en|de|fr|ja|ko|pl|ru|vi|pt|it|nl|cs|sv|th|id|es|zh-CN)/:path*",
      "destination": "/avalon/index.html"
    }
  ]
}
